// stho — JS soup + stho atoms, with an external tokenizer for the IO path so
// "/" reads as a leg separator inside a path but stays a regex|divide in JS,
// and a path stays whitespace-tight (a separator followed by a space ends it,
// letting IO atoms sit inside JS lists|args).
@top Program { Line* }
@skip { space }
Line { lineItem* newline }

@precedence { callparen @left, sigilsuffix @left, ioverb @left }

@external tokens pathSep from "./io_tokens" { PathSep, PathComma, PathColon }

lineItem {
  Comment | LineComment |
  ControlFlow | Sunpit | IOing | IOness | IOness2 | MethodLike | AmpCall | AmpAmp |
  Name | Number | StringVal | TemplateVal | Regex |
  LParen | LBrack | RBrack | Comma | Colon | PuddleSigil | Sigil | Punct
}

ControlFlow { ControlFlowHead }
ControlFlowHead { ElseIfKeyword | ControlKeyword | ElseKeyword }

Sunpit { Sunpitness IOing }
IOing  { IOness !ioverb IOpath | IOness2 !ioverb IOpath (!ioverb IOpath)? }
IOpath { Leg (PathSep Leg)* }
Leg    { PeelGroup }
PeelGroup { PeelItem (PathComma PeelItem)* }
PeelItem  { PuddleSigil? PeelKey (PathColon PeelVal)? }
PeelKey   { Sigil? Name (!sigilsuffix Sigil)? }
PeelVal   { Sigil? Name (!sigilsuffix Sigil)? | Number | StringVal | TemplateVal }

AmpCall { AmpCallTok }
MethodLike { Name !callparen LParen }

@tokens {
  space { (" " | "\t")+ }
  newline { "\n" }
  ControlKeyword { "if " | "for " | "while " | "until " }
  ElseIfKeyword  { "else if " | "elsif " }
  ElseKeyword    { "else " | "else" }
  Sunpitness     { "S " }
  IOness  { ("i" | "o" | "oa" | "ob" | "o1" | "oa1" | "bo" | "boa" | "bo1" | "boa1" | "drop" | "empty") " " }
  IOness2 { ("oai" | "roai" | "moai" | "doai" | "r") " " }

  Name   { (@asciiLetter | "_") (@asciiLetter | "_" | @digit)* }
  Number { (@digit+ ("." @digit+)?) | ("0x" (@digit | $[a-fA-F])+) }
  StringVal   { "'" ("\\" _ | !['\\\n])* "'" | '"' ("\\" _ | !["\\\n])* '"' }
  TemplateVal { "`" ("\\" _ | ![`\\])* "`" }
  LineComment { "//" ![\n]* }
  Comment     { "#" ![\n]* }
  Regex { "/" ![/*=\n \t] ("\\" ![\n] | ![/\\\n])* "/" (@asciiLetter)* }

  AmpCallTok { "&" (@asciiLetter | "_") (@asciiLetter | "_" | @digit)* }
  AmpAmp { "&&" }

  LParen { "(" }
  LBrack { "[" }
  RBrack { "]" }
  Comma { "," }
  Colon { ":" }
  PuddleSigil { "%" }
  Sigil { "@" | "$" }
  Punct { ( "=" | "<" | ">" | "!" | "+" | "-" | "*" | "/" | "%" | "&" | "|" | "?" | "~" | "^" | ")" | "{" | "}" | "." | ";" )+ }

  @precedence {
    LineComment, Regex,
    ElseIfKeyword, ElseKeyword, ControlKeyword, Sunpitness, IOness, IOness2,
    Number, Name, StringVal, TemplateVal, Comment,
    AmpCallTok, AmpAmp, LParen, LBrack, RBrack, Comma, Colon, PuddleSigil, Sigil, Punct
  }
}
