Waft:Trope/Lies/NormalEntropy,boring,dontSnap
  EntropyArrest
    Entcase:Languinio_Interest-waft
      lematch,Languinio
        lematch,Interest:Ting,waft,face,presence,state
          {"means":1,"spayer":1,"re":"Interest:Ting,waft:Ting/202\\d+-\\d+-{INT}/{INT},face:DocTing,presence:always,state:live","tol":"any"}
    Entcase:Ting_cursor-what
      lematch,Interest:Ting,waft,face,presence,state
        lematch,cursor,what,latest
          {"means":1,"spayer":1,"re":"cursor,what:Ting/202\\d-\\d+-{INT}/{INT},latest","tol":"any"}
    Entcase:w_self-round
      lematch,w/self,round
        {"means":1,"spayer":1,"re":"self,round={NUM}","tol":"band","factor":1.5}
    Entcase:wants_want-want
      lematch,req:wants
        lematch,want,kind
          means,spayer,re:want={NUM},tol:band,factor=1.5
    Entcase:Lies_Waft:Ting
      lematch,w:Lies
        lematch,Waft,takes
          means,spayer,re:Waft:Ting/{INT}-{INT}-{INT}/{INT}.takes,tol:any
    Entcase:Lies_log-source-write
      lematch,w:Lies
        lematch,log:source_write
          means,drop
    Entcase:Compile_time-compile
      lematch,Compile
        lematch,time,compile,all,write
          {"means":1,"spayer":1,"re":"time,compile={NUM},all={NUM}(?:,write={NUM})?","tol":"band","factor":2.53,"slack":0.5}
    Entcase:Change_compile-secs
      lematch,Change
        lematch,compile,dige,secs,dim,pending
          means,spayer,re:secs={NUM},tol:band,factor=0.52,slack=0.2
    Entcase:Keep_WaftTimes-times
      lematch,Waft:Keep
        lematch,WaftTimes,of_Waft,discovered_at,accessed_at
          {"means":1,"spayer":1,"re":"discovered_at={NUM},accessed_at={NUM}","tol":"any"}
    Entcase:Keep_WaftTimes-cursor-at
      lematch,Waft:Keep
        lematch,WaftTimes,of_Waft
          lematch,Cursor,what,at
            {"means":1,"spayer":1,"re":"at={NUM}","tol":"any"}
    Entcase:Keep_own-cursor-at
      lematch,Waft:Keep
        lematch,Cursor,waft,at
          {"means":1,"spayer":1,"re":"at={NUM}","tol":"any"}
