  H:PotPlant,Run
    A:PotPlant
      {"mung":["age"]}	self,round:6
      w:PotPlant
        body,hands:2
          pot:cactus
            plant
            soil,dose:5
        shelf
          pot:rose
            plant
            soil,dose:5
          pot:fern
            plant
            soil,dose:5
        yard
          soil,dose:6
        De:repot,init_seq:6
          req:move_inside,maz:3,init_seq:12
        De:celebrate,maz:2
        log
          msg:carrying rose
          msg:carrying fern
          msg:rose in yard
          msg:fern in yard
          msg:carrying cactus
          msg:cactus in yard
          {"msg":"repotted rose (yard soil: 10)"}
          {"msg":"repotted fern (yard soil: 8)"}
          {"msg":"repotted cactus (yard soil: 6)"}
          msg:rose back on shelf
          msg:fern back on shelf
        {"mung":["age"]}	self,round:6
    {"mung":["id"]}	mo:main,interval:3.6
