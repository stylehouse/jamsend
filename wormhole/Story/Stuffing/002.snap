        Example,name:presence
          Track,title:Alve,remaster
          Track,title:Bore,remaster
          Track,title:Cusp,remaster
          Track,title:Dell
          Track,title:Etch
          Vtuffing,of:stuff,n=5
            Vrow,row:spread,k:title,wgt
              Vbit,v:Alve,n
              Vbit,v:Bore,n
