              Vbit,v:Reed,n
            Vrow,row:fact,k:genre,v:dub,wgt
            Vrow,row:fact,k:mood,v:dub,wgt
        Example,name:overflow
          Track,title:Comp,label:blue
          Track,title:Comp,label:warp
          Track,title:Comp,label:deep
          Track,title:Comp,label:on-u
          Track,title:Comp,label:wackies
