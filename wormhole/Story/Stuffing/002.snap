Snap:H
  H:Stuffing,Run
    A:Stuffing
      self,round=2	{"mung":["age"]}
      w:Stuffing
        self,round=2	{"mung":["age"]}
        req:wrangle,eternal,ok
        Example,name:agree
          Track,title:Tide,genre:dub
          Track,title:Halo,genre:dub
          Track,title:Drift,genre:dub
          Track,title:Glow,genre:dub
          Track,title:Vane,genre:dub
          Vtuffing,of:stuff,n=5
            Vrow,row:spread,k:title,wgt
              Vbit,v:Tide,n
              Vbit,v:Halo,n
              Vbit,v:Drift,n
              Vbit,text:+2,n=0
            Vrow,row:fact,k:genre,v:dub,wgt
        Example,name:spread
          Track,title:Ember,year:2007
          Track,title:Frost,year:2007
          Track,title:Gale,year:1998
          Vtuffing,of:stuff,n=3
            Vrow,row:spread,k:title,wgt
              Vbit,v:Ember,n
              Vbit,v:Frost,n
              Vbit,v:Gale,n
            Vrow,row:spread,k:year,wgt
              Vbit,v:2007,n=2
              Vbit,v:1998,n
        Example,name:vein
          Track,title:Sway,genre:dub
          Track,title:Murk,mood:dub
          Track,title:Reed,genre:dub
          Vtuffing,of:stuff,n=3
            Vrow,row:vein,v:dub,wgt
              Vbit,k:genre,n=2
              Vbit,k:mood,n
            Vrow,row:spread,k:title,wgt
              Vbit,v:Sway,n
              Vbit,v:Murk,n
              Vbit,v:Reed,n
        Example,name:coexist
          Track,title:Sway,genre:dub
          Track,title:Murk,mood:dub
          Track,title:Reed,genre:dub
          Vtuffing,of:stuff,n=3
            Vrow,row:vein,v:dub,wgt
