                     //   ;(A.doai({req: "step", seq: 2}, {demand: 800}))?.(async (req) => {
                     //       A.i({started: 1}); await req.r({ok: 1})
                     //   })
                     A.doai({req: "step", seq: 2}, {demand: 800})?.(async (req) => {
                         A.i({started: 1})
                         await req.r({ok: 1})
                 
                     })
                     // a level folded into the identity path instead of a separate props path:
                     //   ;(w.doai({req: "waft_roster", eternal: 1}))?.(async (req) => { … })
                     w.doai({req: "waft_roster", eternal: 1})?.(async (req) => {
