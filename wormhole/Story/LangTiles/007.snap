                 //  three seams that used to force raw JS, now tiles.
                 async ampTiles(A,w) {
                     const H = this
                     // (1) recv&method → recv.method(args): a tight identifier before "&" is the
                     //  receiver, the way a leading bareword is for i/o.  pier.do(), req.bump():
                     pier.do()
                     req.bump()
