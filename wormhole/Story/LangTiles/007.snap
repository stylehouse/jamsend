                     let pier = this._o_drill1(w, [{sc: {A: side}, exactly: {A: true}}, {sc: {w: "Peeroleum"}, exactly: {w: true}}, {sc: {Pier: 1}}])
                     // value-out keeps the dot:  .$:name  →  let ang = …?.sc.wither
