[Unit]
Description=jamsend-droids Docker Compose Application Service
Requires=docker.service leproxy.service jamsend-prod.service
After=docker.service network-online.target leproxy.service jamsend-prod.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/s/src/jamsend/ty
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
