[Unit]
Description=Jamsend Chrome profiles (cold start)
After=jamsend-xvfb.service
Requires=jamsend-xvfb.service

[Service]
User=jamsend
Type=oneshot
# RemainAfterExit: the Chromes outlive this script; the unit stays active so dependents are happy
RemainAfterExit=yes
Environment=DISPLAY=:10
Environment=XDG_RUNTIME_DIR=/run/user/1000
EnvironmentFile=/opt/jamsend-src/ty/jamsend-supervisor.conf
# PROFILE_BASE must come after EnvironmentFile so it overrides the host path in the conf;
# profiles live on the VM disk so they're captured in snapshots
Environment=PROFILE_BASE=/home/jamsend/.chrome-profiles
ExecStart=/usr/bin/python3 /opt/jamsend-src/ty/chrome-starter.py

[Install]
WantedBy=multi-user.target
