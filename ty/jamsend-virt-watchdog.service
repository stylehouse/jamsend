[Unit]
Description=Jamsend Puppeteer Watchdog (VM-native)
After=jamsend-virt-chromium.service
Requires=jamsend-virt-chromium.service

[Service]
User=jamsend
Type=simple
WorkingDirectory=/opt/jamsend-src/ty
EnvironmentFile=/opt/jamsend-src/ty/jamsend-supervisor.conf
ExecStart=/usr/bin/node /opt/jamsend-src/ty/watchdog.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
