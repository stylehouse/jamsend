[Unit]
Description=jamsend-prod Application Service
Wants=docker.service leproxy.service network-online.target
After=docker.service network-online.target leproxy.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/s/src/prod-jamsend
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
