[Unit]
Description=prod-jamsend Docker Compose Application Service
Requires=docker.service leproxy.service
After=docker.service network-online.target leproxy.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/s/src/prod-jamsend
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
