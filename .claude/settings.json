{
  "$schema": "https://json-schema.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./ty/.env.chrome-profiles)",
      "Read(./ty/droidlounge/.env.chrome-profiles)",
      "Read(**/.env.chrome-profiles)"
    ]
  }
}
